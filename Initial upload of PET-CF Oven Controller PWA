/* PET-CF Oven Controller Styles */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: #0f172a;
    color: #e2e8f0;
    min-height: 100vh;
}

.container {
    max-width: 480px;
    margin: 0 auto;
    padding: 16px;
}

header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid #334155;
}

h1 {
    font-size: 1.5rem;
    color: #60a5fa;
}

.status {
    padding: 6px 12px;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
}

.idle { background: #475569; color: white; }
.connected { background: #22c55e; color: black; }

.temp-section {
    background: #1e2937;
    border-radius: 16px;
    padding: 32px 24px;
    text-align: center;
    margin-bottom: 24px;
}

.temp-display {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 8px;
}

.temp-value {
    font-size: 4.5rem;
    font-weight: 700;
    line-height: 1;
    color: #f1f5f9;
}

.temp-unit {
    font-size: 1.5rem;
    color: #94a3b8;
}

.temp-label {
    margin-top: 8px;
    font-size: 1.1rem;
    color: #cbd5e1;
}

.status-bar {
    background: #1e2937;
    padding: 12px;
    text-align: center;
    border-radius: 12px;
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 24px;
}

.btn {
    width: 100%;
    padding: 16px;
    margin: 8px 0;
    border: none;
    border-radius: 12px;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
}

.primary { background: #3b82f6; color: white; }
.success { background: #22c55e; color: black; }
.warning { background: #eab308; color: black; }
.danger { background: #ef4444; color: white; }

.control-group {
    display: flex;
    gap: 12px;
}

.form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 16px 0;
}

label {
    display: block;
    margin-bottom: 4px;
    font-size: 0.95rem;
    color: #94a3b8;
}

input {
    width: 100%;
    padding: 12px;
    background: #334155;
    border: 1px solid #475569;
    border-radius: 8px;
    color: white;
    font-size: 1rem;
}

.logs {
    margin-top: 24px;
}

.log-window {
    background: #0f172a;
    border: 1px solid #334155;
    border-radius: 12px;
    height: 180px;
    overflow-y: auto;
    padding: 12px;
    font-family: monospace;
    font-size: 0.85rem;
    line-height: 1.4;
    color: #94a3b8;
}

footer {
    text-align: center;
    margin-top: 32px;
    color: #64748b;
    font-size: 0.8rem;
