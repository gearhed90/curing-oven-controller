// PET-CF Annealing Oven Controller - Web Bluetooth PWA
let device = null;
let characteristic = null;
let currentTemp = 25.0;
let isHeating = false;
let currentMode = 'Idle';
let interval = null;

const tempEl = document.getElementById('current-temp');
const modeEl = document.getElementById('current-mode');
const statusEl = document.getElementById('connection-status');
const logEl = document.getElementById('log');

function log(message, type = 'info') {
    const time = new Date().toLocaleTimeString();
    const entry = document.createElement('div');
    entry.textContent = `[${time}] ${message}`;
    if (type === 'error') entry.style.color = '#f87171';
    if (type === 'success') entry.style.color = '#4ade80';
    logEl.appendChild(entry);
    logEl.scrollTop = logEl.scrollHeight;
}

// Simulated temperature update
function simulateTemperature() {
    if (isHeating) {
        currentTemp += (Math.random() * 1.2) + 0.3;
        if (currentTemp > 120) currentTemp = 120;
    } else if (currentTemp > 25) {
        currentTemp -= 0.4;
    }
    tempEl.textContent = currentTemp.toFixed(1);
}

// Web Bluetooth Connection (simulated for demo - real UUIDs would match your ESP32 GATT)
async function connectToOven() {
    try {
        log("Requesting Bluetooth device...");
        
        // Real implementation would be:
        // device = await navigator.bluetooth.requestDevice({
        //     filters: [{ namePrefix: 'PET-CF' }],
        //     optionalServices: ['your-service-uuid']
        // });
        
        // For demo purposes, simulate successful connection
        setTimeout(() => {
            device = { name: "PET-CF-Oven-ESP32" };
            statusEl.textContent = "Connected";
            statusEl.className = "status connected";
            log("Connected to PET-CF Oven", "success");
            
            // Start simulated updates
            if (!interval) {
                interval = setInterval(simulateTemperature, 1200);
            }
        }, 800);
        
    } catch (error) {
        log("Connection failed: " + error.message, "error");
    }
}

// Full Power Test
function fullPowerTest() {
    if (!device) {
        log("Please connect first", "error");
        return;
    }
    log("Full Power Test activated - Heating + Fan at 100%", "warning");
    isHeating = true;
    currentMode = "Full Power";
    modeEl.textContent = currentMode;
}

// Emergency Stop
function emergencyStop() {
    isHeating = false;
    currentMode = "Emergency Stop";
    modeEl.textContent = currentMode;
    log("EMERGENCY STOP ACTIVATED - All systems halted", "error");
    setTimeout(() => {
        currentMode = "Idle";
        modeEl.textContent = currentMode;
    }, 2000);
}

// Start Annealing Program
function startAnnealing() {
    if (!device) {
        log("Connect to oven first", "error");
        return;
    }
    
    const target = parseFloat(document.getElementById('target-temp').value);
    const ramp = parseFloat(document.getElementById('ramp-rate').value);
    const hold = parseFloat(document.getElementById('hold-time').value);
    const cool = parseFloat(document.getElementById('cool-rate').value);
    
    log(`Starting annealing cycle: Target ${target}°C, Ramp ${ramp}°C/min, Hold ${hold} min`);
    
    isHeating = true;
    currentMode = "Ramping";
    modeEl.textContent = currentMode;
    
    // Simple simulation of cycle
    setTimeout(() => {
        currentMode = "Holding";
        modeEl.textContent = currentMode;
        log("Reached target - Holding temperature", "success");
    }, 8000);
    
    setTimeout(() => {
        isHeating = false;
        currentMode = "Cooling";
        modeEl.textContent = currentMode;
        log("Cooling down phase started");
    }, 8000 + hold * 1000);
}

// Manual controls
document.getElementById('manual-heat').addEventListener('click', () => {
    isHeating = true;
    currentMode = "Manual Heating";
    modeEl.textContent = currentMode;
    log("Manual heating started");
});

document.getElementById('manual-stop').addEventListener('click', () => {
    isHeating = false;
    currentMode = "Idle";
    modeEl.textContent = currentMode;
    log("Heating stopped");
});

// Button listeners
document.getElementById('connect-btn').addEventListener('click', connectToOven);
document.getElementById('full-power-btn').addEventListener('click', fullPowerTest);
document.getElementById('emergency-stop').addEventListener('click', emergencyStop);
document.getElementById('start-program').addEventListener('click', startAnnealing);

